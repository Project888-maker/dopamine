[Unit]
Description=Dopamine Telegram Bot
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/pipeline
EnvironmentFile=/home/ubuntu/pipeline/.env
ExecStart=/home/ubuntu/pipeline/.venv/bin/python telegram_bot.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
